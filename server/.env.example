# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,https://rugan-web.vercel.app,https://rugan.org,https://www.rugan.org

# MongoDB Atlas (replace with your connection string)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/rugan?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Email (Nodemailer via any SMTP provider, including Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_login
SMTP_PASS=your_brevo_smtp_key
EMAIL_FROM=RUGAN <hello@rugan.org>

BREVO_API_KEY=your_brevo_api_key_here

# Admin notifications and bootstrap admin user
ADMIN_NAME=RUGAN Admin
ADMIN_EMAIL=admin@rugan.org
ADMIN_PASSWORD=your_secure_admin_password_here

# Paystack (get from https://dashboard.paystack.com/settings/developer)
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key_here

# Google Sheets (create service account and share sheet)
VOLUNTEER_SHEET_ID=your_google_sheet_id_here
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"your_project_id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Frontend URL
FRONTEND_URL=https://rugan.org,https://www.rugan.org

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
